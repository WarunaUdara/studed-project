{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/src/routeTree.gen.ts",
      "!**/src/styles/index.css",
      "!**/src/components/ui/achievement-badge.tsx",
      "!**/src/components/ui/leaderboard-rankings.tsx",
      "!**/src/components/ui/points-badge.tsx",
      "!**/src/components/ui/points-levels-timeline.tsx",
      "!**/src/components/ui/streak-badge.tsx"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "noLabelWithoutControl": "off"
      },
      "style": {
        "useNodejsImportProtocol": "off",
        "noNonNullAssertion": "off"
      }
    }
  }
}
